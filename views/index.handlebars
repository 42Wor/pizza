<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Red & Chilli Pizza Cafe</title>
    
    <link rel="icon" href="/image/ican.webp" type="image/png">
    <link rel="preload" as="image" href="/image/log.webp">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary: #E74C3C;
            --bg-dark: #121212;
            --bg-card: #1E1E1E;
            --text-white: #ffffff;
            --text-gray: #9ca3af;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Outfit', sans-serif; -webkit-tap-highlight-color: transparent; }
        body { background-color: var(--bg-dark); color: var(--text-white); overflow-x: hidden; padding-bottom: 80px; }

        .navbar { position: fixed; top: 0; width: 100%; padding: 10px 5%; background: rgba(18, 18, 18, 0.9); backdrop-filter: blur(10px); z-index: 100; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; gap: 12px; }
        .brand { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 1.1rem; color: white; text-decoration: none; letter-spacing: 1px; }
        .brand span { color: var(--primary); }
        .nav-logo-img { height: 45px; width: 45px; border-radius: 50%; object-fit: cover; border: 2px solid var(--primary); }

        .hero { margin-top: 85px; padding: 0 5%; margin-bottom: 30px; }
        .hero h1 { font-size: 2rem; line-height: 1.2; }
        .hero p { color: var(--text-gray); margin-top: 5px; }

        .section-title { font-size: 1.4rem; font-weight: 800; margin: 0 5% 15px; display: flex; align-items: center; gap: 10px; }
        .section-title i { color: var(--primary); }

        .deals-wrapper { display: flex; overflow-x: auto; gap: 15px; padding: 0 5% 30px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
        .deals-wrapper::-webkit-scrollbar { display: none; }
        
        .deal-card { min-width: 280px; max-width: 320px; background: var(--bg-card); border-radius: 16px; overflow: hidden; scroll-snap-align: center; border: 1px solid rgba(255,255,255,0.1); position: relative; flex-shrink: 0; transition: transform 0.2s ease; cursor: pointer; }
        .deal-badge { position: absolute; top: 10px; left: 10px; background: var(--primary); color: white; padding: 4px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 800; }
        .deal-img { width: 100%; height: 150px; object-fit: cover; }
        .deal-content { padding: 15px; }
        .deal-name { font-size: 1.1rem; font-weight: 700; margin-bottom: 5px; }
        .deal-desc { font-size: 0.8rem; color: #aaa; margin-bottom: 10px; height: 35px; overflow: hidden; }
        .deal-footer { display: flex; justify-content: space-between; align-items: center; }
        .deal-price { font-size: 1.2rem; color: var(--primary); font-weight: 800; }

        .category-strip { position: sticky; top: 65px; z-index: 90; background: var(--bg-dark); padding: 10px 5%; display: flex; gap: 10px; overflow-x: auto; border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px; }
        .category-strip::-webkit-scrollbar { display: none; }
        .cat-pill { padding: 8px 20px; border-radius: 50px; background: var(--bg-card); border: 1px solid rgba(255,255,255,0.1); color: #aaa; font-weight: 600; white-space: nowrap; cursor: pointer; transition: 0.2s; }
        .cat-pill.active { background: var(--primary); color: white; border-color: var(--primary); }

        .menu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 15px; padding: 0 5%; }
        .menu-card { background: var(--bg-card); border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); display: flex; flex-direction: column; }
        .menu-img { width: 100%; height: 120px; object-fit: cover; }
        .menu-content { padding: 10px; flex-grow: 1; display: flex; flex-direction: column; }
        .menu-name { font-size: 0.95rem; font-weight: 700; margin-bottom: 5px; }
        .menu-desc { font-size: 0.75rem; color: #777; margin-bottom: 10px; flex-grow: 1; }
        .menu-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
        .btn-icon { width: 30px; height: 30px; background: rgba(255,255,255,0.1); color: white; border: none; border-radius: 6px; cursor: pointer; display: flex; align-items: center; justify-content: center; }
        .btn-icon:hover { background: var(--primary); color: white; }

        .fab-cart { position: fixed; bottom: 25px; right: 25px; width: 60px; height: 60px; background: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 20px rgba(231, 76, 60, 0.4); cursor: pointer; z-index: 1000; }
        .fab-count { position: absolute; top: -5px; right: -5px; background: white; color: black; font-weight: 800; font-size: 0.8rem; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1001; opacity: 0; pointer-events: none; transition: 0.3s; }
        .overlay.active { opacity: 1; pointer-events: all; }
        .sidebar { position: fixed; top: 0; right: -100%; width: 85%; max-width: 400px; height: 100%; background: #1a1d24; z-index: 1002; transition: 0.3s; display: flex; flex-direction: column; }
        .sidebar.active { right: 0; }
        .sidebar-header { padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: center; }
        .sidebar-body { flex-grow: 1; overflow-y: auto; padding: 15px; }
        .cart-item { display: flex; gap: 10px; margin-bottom: 15px; background: rgba(255,255,255,0.05); padding: 8px; border-radius: 8px; align-items: center; }
        .cart-item img { width: 50px; height: 50px; border-radius: 6px; object-fit: cover; }
        .sidebar-footer { padding: 20px; background: #14161b; }
        .input-field { width: 100%; background: #2a2d35; border: 1px solid #444; padding: 12px; border-radius: 8px; color: white; margin-bottom: 10px; font-size: 0.9rem; }
        /* search */
        .search-container { padding: 0 5%; margin-bottom: 10px; }
        .search-wrapper { position: relative; }
        .search-wrapper .input-field { padding-right: 40px; }
        .search-clear { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: transparent; border: none; color: rgba(255,255,255,0.6); cursor: pointer; font-size: 0.95rem; padding: 6px; border-radius: 6px; display: flex; align-items: center; justify-content: center; }
        .search-clear:hover { color: var(--primary); background: rgba(255,255,255,0.03); }
        /* utility */
        .hidden { display: none !important; }
        .accent { color: var(--primary); }
        .no-deals { text-align: center; color: #777; margin: 10px 5%; }
        .deal-prompt { color: var(--text-gray); font-size: 0.8rem; }
        .menu-price { font-weight: 700; color: var(--primary); }
        .fab-icon { font-size: 1.4rem; color: white; }
        .close-icon { cursor: pointer; font-size: 1.2rem; }
        .total-row { display:flex; justify-content:space-between; margin-bottom:15px; font-weight:800; font-size:1.2rem; }
        .cart-total-amount { color: var(--primary); }
        .empty-cart { text-align:center; color:#777; margin-top:20px; }
        .cart-item-body { flex-grow: 1; }
        .cart-item-name { font-size:0.9rem; font-weight:600; }
        .cart-item-price { color:var(--primary); font-size:0.85rem; }
        .cart-trash { color:#ff4444; cursor:pointer; }
        .checkout-btn { width: 100%; padding: 14px; background: #25D366; color: white; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; }
        
        .toast { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 10px 20px; border-radius: 30px; z-index: 2000; font-size: 0.9rem; animation: fade 2s forwards; }
        @keyframes fade { 0% { opacity: 0; top: 0; } 20% { opacity: 1; top: 20px; } 80% { opacity: 1; top: 20px; } 100% { opacity: 0; top: 0; } }

        /* --- NEW: Deal Details Modal --- */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); backdrop-filter: blur(5px);
            z-index: 1050; opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
        }
        .modal-overlay.active { opacity: 1; pointer-events: all; }

        .deal-modal {
            position: fixed; top: 50%; left: 50%;
            transform: translate(-50%, -50%) scale(0.9);
            width: 90%; max-width: 450px;
            background: var(--bg-card); border-radius: 20px;
            z-index: 1051; opacity: 0; pointer-events: none;
            transition: opacity 0.3s ease, transform 0.3s ease;
            border: 1px solid rgba(255,255,255,0.1);
            overflow: hidden;
        }
        .deal-modal.active { opacity: 1; pointer-events: all; transform: translate(-50%, -50%) scale(1); }

        .modal-close {
            position: absolute; top: 15px; right: 15px; font-size: 1.5rem; color: white; cursor: pointer;
            background: rgba(0,0,0,0.5); width: 35px; height: 35px;
            border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 2;
        }
        .modal-img { width: 100%; height: 220px; object-fit: cover; }
        .modal-content { padding: 20px; }
        .modal-content h2 { font-size: 1.8rem; margin-bottom: 10px; }
        .modal-content p { font-size: 1rem; color: var(--text-gray); line-height: 1.6; margin-bottom: 20px; }
        .modal-footer { display: flex; justify-content: space-between; align-items: center; }
        .modal-footer span { font-size: 1.8rem; font-weight: 800; color: var(--primary); }
        .modal-footer button { padding: 12px 25px; font-size: 1rem; background: var(--primary); color: white; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="#" class="brand">
            <img src="/image/log.webp" alt="Logo" class="nav-logo-img" width="45" height="45" decoding="async">
            RED & <span>CHILLI</span>
        </a>
    </nav>

    <div class="hero">
        <h1>Taste the <span class="accent">Flames.</span></h1>
        <p>Pizza, Burgers & More. Delivered Fast.</p>
    </div>

    <div class="search-container">
        <div class="search-wrapper">
            <input id="menu-search" class="input-field" placeholder="Search menu (name or description)..." aria-label="Search menu" autocomplete="off">
            <button id="search-clear" class="search-clear hidden" aria-label="Clear search" title="Clear search"><i class="fas fa-times"></i></button>
        </div>
    </div>

    <div class="section-title"><i class="fas fa-fire"></i> Hot Deals</div>
    <p id="no-deals" class="no-deals hidden">No deals found</p>
    <div class="deals-wrapper">
        {{#each deals}}
        <!-- UPDATED: Card now opens modal on click -->
        <div class="deal-card" onclick="showDealDetails({{this.id}})">
            <div class="deal-badge">SAVE MONEY</div>
            <img src="{{this.image}}" class="deal-img" width="320" height="150" decoding="async">
            <div class="deal-content">
                <div class="deal-name">{{this.name}}</div>
                <div class="deal-desc">{{this.description}}</div>
                <div class="deal-footer">
                    <div class="deal-price">₨{{this.price}}</div>
                    <!-- UPDATED: Removed button, added prompt -->
                    <div class="deal-prompt">View Details <i class="fas fa-arrow-right"></i></div>
                </div>
            </div>
        </div>
        {{/each}}
    </div>

    <div class="section-title"><i class="fas fa-utensils"></i> Our Menu</div>

    <div class="category-strip" id="category-container">
        {{#each categories}}
          <button class="cat-pill {{#if @first}}active{{/if}}" data-cat="{{this.key}}" onclick="filterMenu(this)">{{this.label}}</button>
        {{/each}}
    </div>

    <div class="menu-grid" id="menu-grid">
      {{#each menu}}
      <div class="menu-card" data-type="{{type}}" data-id="{{id}}">
        <img src="{{image}}" class="menu-img" width="160" height="120" decoding="async" loading="lazy">
        <div class="menu-content">
          <div class="menu-name">{{name}}</div>
          <div class="menu-desc">{{description}}</div>
          <div class="menu-footer">
            <div class="menu-price">₨{{price}}</div>
            <button class="btn-icon" onclick="addToCart({{id}})"><i class="fas fa-plus"></i></button>
          </div>
        </div>
      </div>
      {{/each}}
    </div>

    <div class="fab-cart" onclick="toggleCart()">
        <i class="fas fa-shopping-bag fab-icon"></i>
        <div class="fab-count" id="cart-count">0</div>
    </div>

    <div class="overlay" id="overlay" onclick="toggleCart()"></div>
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h3>Your Order</h3>
            <i class="fas fa-times close-icon" onclick="toggleCart()"></i>
        </div>
        <div class="sidebar-body" id="cart-items"></div>
        <div class="sidebar-footer">
            <div class="total-row">
                <span>Total:</span> <span id="cart-total" class="cart-total-amount">₨0</span>
            </div>
            <input type="text" id="customer-name" class="input-field" placeholder="Full Name">
            <input type="tel" id="customer-phone" class="input-field" placeholder="Phone Number (e.g. 03277757234)">
            <input type="text" id="customer-address" class="input-field" placeholder="Delivery Address">
            <button class="checkout-btn" onclick="checkout()">ORDER ON WHATSAPP</button>
        </div>
    </div>

    <div id="toast-container"></div>

    <!-- NEW: Deal Details Modal HTML -->
    <div class="modal-overlay" id="modal-overlay" onclick="closeDealModal()"></div>
    <div class="deal-modal" id="deal-modal">
        <i class="fas fa-times modal-close" onclick="closeDealModal()"></i>
        <img src="" alt="Deal Image" id="modal-image" class="modal-img" width="450" height="220" decoding="async">
        <div class="modal-content">
            <h2 id="modal-name"></h2>
            <p id="modal-description"></p>
            <div class="modal-footer">
                <span id="modal-price"></span>
                <button id="modal-add-btn">ADD TO CART</button>
            </div>
        </div>
    </div>

    <script>
        const menuData = {{{json menu}}};
        const dealsData = {{{json deals}}};
        const allProducts = [...dealsData, ...menuData];
        let cart = [];

        // Categories/menu rendered on server via Handlebars; client uses filterMenu() to filter.

        function addToCart(id) {
            const item = allProducts.find(p => p.id === id);
            if(item) {
                const cartItem = cart.find(p => p.id === id);
                if (cartItem) {
                    cartItem.quantity++;
                } else {
                    cart.push({...item, quantity: 1});
                }
                updateCartUI();
                showToast(`Added ${item.name}`);
            }
        }

        function removeFromCart(id) {
            const itemIndex = cart.findIndex(p => p.id === id);
            if (itemIndex > -1) {
                const item = cart[itemIndex];
                if (item.quantity > 1) {
                    item.quantity--;
                } else {
                    cart.splice(itemIndex, 1);
                }
                updateCartUI();
            }
        }

        function updateCartUI() {
            document.getElementById('cart-count').innerText = cart.reduce((sum, item) => sum + item.quantity, 0);
            const list = document.getElementById('cart-items');
            const totalEl = document.getElementById('cart-total');
            list.innerHTML = '';
            let total = 0;
            if(cart.length === 0) list.innerHTML = '<p class="empty-cart">Cart is empty</p>';
            cart.forEach((item) => {
                total += item.price * item.quantity;
                list.innerHTML += `
                    <div class="cart-item">
                        <img src="${item.image}" width="50" height="50" decoding="async">
                        <div class="cart-item-body">
                            <div class="cart-item-name">${item.name} (x${item.quantity})</div>
                            <div class="cart-item-price">₨${item.price}</div>
                        </div>
                        <i class="fas fa-trash cart-trash" onclick="removeFromCart(${item.id})"></i>
                    </div>
                `;
            });
            totalEl.innerText = '₨' + total;
        }

        function toggleCart() {
            document.getElementById('sidebar').classList.toggle('active');
            document.getElementById('overlay').classList.toggle('active');
        }

        function checkout() {
            if(cart.length === 0) return showToast('Cart is empty!');
            const name = document.getElementById('customer-name').value.trim();
            const phone = document.getElementById('customer-phone').value.trim();
            const address = document.getElementById('customer-address').value.trim();
            if(!name || !phone || !address) return showToast('Please fill all delivery details!');
            let msg = `*NEW ORDER - Red & Chilli Pizza Cafe*\n------------------\n`;
            cart.forEach((item, i) => { msg += `${i+1}. ${item.name} (₨${item.price})\n`; });
            const total = cart.reduce((sum, i) => sum + i.price, 0);
            msg += `------------------\n*Total: ₨${total}*\n\n*Customer Details:*\n*Name:* ${name}\n*Phone:* ${phone}\n*Address:* ${address}`;
            const businessPhone = "923277757234"; 
            window.open(`https://wa.me/${businessPhone}?text=${encodeURIComponent(msg)}`, '_blank');
        }

        function showToast(msg) {
            const div = document.createElement('div');
            div.className = 'toast';
            div.innerText = msg;
            document.getElementById('toast-container').appendChild(div);
            setTimeout(() => div.remove(), 2000);
        }

        // --- NEW: Modal Functions ---
        function showDealDetails(dealId) {
            const deal = dealsData.find(d => d.id === dealId);
            if (!deal) return;

            document.getElementById('modal-image').src = deal.image;
            document.getElementById('modal-name').innerText = deal.name;
            document.getElementById('modal-description').innerText = deal.description;
            document.getElementById('modal-price').innerText = `₨${deal.price}`;
            
            const addBtn = document.getElementById('modal-add-btn');
            addBtn.onclick = () => {
                addToCart(deal.id);
                closeDealModal();
            };

            document.getElementById('modal-overlay').classList.add('active');
            document.getElementById('deal-modal').classList.add('active');
        }

        function closeDealModal() {
            document.getElementById('modal-overlay').classList.remove('active');
            document.getElementById('deal-modal').classList.remove('active');
        }

        // Filter menu by category/search (server-rendered items)
        function filterMenu(btn) {
            document.querySelectorAll('.cat-pill').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            applyFilters();
        }

        function debounce(fn, delay) {
            let t;
            return (...args) => {
                clearTimeout(t);
                t = setTimeout(() => fn(...args), delay);
            };
        }

        function applyFilters() {
            const active = document.querySelector('.cat-pill.active');
            const cat = active ? active.getAttribute('data-cat') : 'all';
            const q = (document.getElementById('menu-search')?.value || '').trim().toLowerCase();

            document.querySelectorAll('.menu-card').forEach(card => {
                const type = (card.getAttribute('data-type') || '').toLowerCase();
                const name = (card.querySelector('.menu-name')?.innerText || '').toLowerCase();
                const desc = (card.querySelector('.menu-desc')?.innerText || '').toLowerCase();

                const matchesCat = (cat === 'all') || (type === cat);
                const matchesQuery = q === '' || name.includes(q) || desc.includes(q);

                card.classList.toggle('hidden', !(matchesCat && matchesQuery));
            });

            // Also filter deals based on the same search query
            let visibleDeals = 0;
            document.querySelectorAll('.deal-card').forEach(deal => {
                const name = (deal.querySelector('.deal-name')?.innerText || '').toLowerCase();
                const desc = (deal.querySelector('.deal-desc')?.innerText || '').toLowerCase();
                const matches = q === '' || name.includes(q) || desc.includes(q);
                deal.classList.toggle('hidden', !matches);
                if (matches) visibleDeals++;
            });

            const noDealsEl = document.getElementById('no-deals');
            if (noDealsEl) noDealsEl.classList.toggle('hidden', visibleDeals !== 0);
        }

        // Wire up search input with debounce and initialize filters
        document.addEventListener('DOMContentLoaded', () => {
            const search = document.getElementById('menu-search');
            const clearBtn = document.getElementById('search-clear');
            if (search) {
                // Debounced filter application for performance
                search.addEventListener('input', debounce(() => applyFilters(), 250));
                // Show/hide clear button immediately when user types
                search.addEventListener('input', () => {
                    if (clearBtn) clearBtn.classList.toggle('hidden', !search.value.trim());
                });
            }
            if (clearBtn && search) {
                clearBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    search.value = '';
                    clearBtn.classList.add('hidden');
                    applyFilters();
                    search.focus();
                });
                // initialize visibility
                clearBtn.classList.toggle('hidden', !(search && search.value.trim()));
            }
            applyFilters();
        });
    </script>
</body>
</html>